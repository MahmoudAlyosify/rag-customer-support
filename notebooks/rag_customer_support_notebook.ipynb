    "# RAG Customer Support — Starter Notebook\n",
    "\n",
    "This notebook is a runnable, opinionated starter for the `rag-customer-support` project.\n",
    "It demonstrates: ingestion & chunking, embedding, indexing to Qdrant, hybrid retrieval (dense + BM25), simple reranking, and a generation example using OpenAI.\n",
    "\n",
    "Follow the full guide in `rag-customer-support-guide.md` for design rationale and next phases."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Prerequisites\n",
    "- Python 3.11+ recommended\n",
    "- Set environment variables in your shell or a `.env` file: `OPENAI_API_KEY` (or other provider keys), and optionally `QDRANT_URL`/`QDRANT_API_KEY`.\n",
    "\n",
    "Install the minimal Python dependencies (run in a notebook cell or terminal):\n",
    "```\n",
    "pip install openai qdrant-client numpy scikit-learn rank_bm25\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Common imports\n",
    "import os\n",
    "import math\n",
    "from typing import List, Dict, Tuple\n",
    "import numpy as np\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "from rank_bm25 import BM25Okapi\n",
    "import openai\n",
    "\n",
    "# Qdrant client (ensure qdrant is running locally or set QDRANT_URL)\n",
    "from qdrant_client import QdrantClient\n",
    "from qdrant_client.http import models as qdrant_models\n",
    "\n",
    "openai.api_key = os.getenv('OPENAI_API_KEY')\n",
    "QDRANT_URL = os.getenv('QDRANT_URL', 'http://localhost:6333')\n",
    "qdrant_client = QdrantClient(url=QDRANT_URL)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def chunk_text(text: str, chunk_size: int = 800, overlap: int = 100) -> List[str]:\n",
    "    \"\"\"A simple chunker that splits by words. This is an approximation of token counts.\n",
    "    For production, replace with a tokenizer-aware splitter (tiktoken or similar) and structure-aware splitting.\n",
    "    \"\"\"\n",
    "    words = text.split()\n",
    "    chunks = []\n",
    "    start = 0\n",
    "    while start < len(words):\n",
    "        end = min(len(words), start + chunk_size)\n",
    "        chunk = ' '.join(words[start:end])\n",
    "        chunks.append(chunk)\n",
    "        start = end - overlap\n",
    "        if start < 0:\n",
    "            start = 0\n",
    "        if end == len(words):\n",
    "            break\n",
    "    return chunks\n",
    "\n",
    "# Quick test\n",
    "sample = ' '.join([f'word{i}' for i in range(2000)])\n",
    "len(chunk_text(sample, chunk_size=500, overlap=50))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_openai_embeddings(texts: List[str], model: str = 'text-embedding-3-small') -> List[List[float]]:\n",
    "    \"\"\"Call OpenAI embeddings for a list of texts. Returns list of vectors.\n",
    "    Make sure OPENAI_API_KEY is set.\n",
    "    \"\"\"\n",
    "    # Batch requests if you have many texts\n",
    "    resp = openai.Embeddings.create(input=texts, model=model)\n",
    "    return [r['embedding'] for r in resp['data']]\n",
    "\n",
    "# Example (small):\n",
    "texts = ['Hello world', 'This is a test']\n",
    "# embeddings = get_openai_embeddings(texts)  # uncomment to run (requires API key)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_qdrant_collection(collection_name: str, vector_size: int):\n",
    "    try:\n",
    "        qdrant_client.get_collection(collection_name)\n",
    "        print(f'Collection \"{collection_name}\" already exists')\n",
    "    except Exception:\n",
    "        print(f'Creating collection \"{collection_name}\" (size={vector_size})')\n",
    "        qdrant_client.recreate_collection(\n",
    "            collection_name=collection_name,\n",
    "            vectors_config=qdrant_models.VectorParams(size=vector_size, distance=qdrant_models.Distance.COSINE),\n",
    "        )\n",
    "\n",
    "def upsert_chunks(collection_name: str, chunks: List[Dict]):\n",
    "    # chunks: list of {\n",
    "    #   'id': str, 'vector': List[float], 'payload': {...},\n",
    "    # }\n",
    "    qdrant_client.upsert(collection_name=collection_name, points=chunks)\n",
    "\n",
    "# Example usage (commented):\n",
    "# create_qdrant_collection('demo_collection', vector_size=1536)\n",
    "# upsert_chunks('demo_collection', [{'id': 1, 'vector': embeddings[0], 'payload': {'text': texts[0]}}])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def rrf(result_lists: List[List[str]], k: int = 60) -> List[str]:\n",
    "    \"\"\"Reciprocal Rank Fusion implementation. Accepts multiple ranked lists of doc ids (strings/ints).\n",
    "    Returns doc ids sorted by fused score.\n",
    "    \"\"\"\n",
    "    scores = {}\n",
    "    for results in result_lists:\n",
    "        for rank, doc_id in enumerate(results):\n",
    "            scores[doc_id] = scores.get(doc_id, 0) + 1.0 / (k + rank + 1)\n",
    "    return sorted(scores.keys(), key=lambda d: scores[d], reverse=True)\n",
    "\n",
    "# Simple test\n",
    "a = ['d1','d2','d3']\n",
    "b = ['d3','d4','d2']\n",
    "rrf([a,b])[:5]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Example retrieval pipeline (in-memory BM25 + Qdrant dense search)\n",
    "from sklearn.preprocessing import normalize\n",
    "\n",
    "def bm25_search(corpus_texts: List[str], query: str, top_n: int = 10) -> List[int]:\n",
    "    tokenized = [doc.split() for doc in corpus_texts]\n",
    "    bm25 = BM25Okapi(tokenized)\n",
    "    scores = bm25.get_scores(query.split())\n",
    "    ranked = np.argsort(scores)[::-1][:top_n]\n",
    "    return ranked.tolist()\n",
    "\n",
    "def dense_search_qdrant(collection_name: str, query_vector: List[float], top_k: int = 10) -> List[int]:\n",
    "    hits = qdrant_client.search(collection_name=collection_name, query_vector=query_vector, limit=top_k)\n",
    "    # hits are objects with .id and .score (distance). Return ids as ints/strs\n",
    "    return [h.id for h in hits]\n",
    "\n",
    "def fuse_and_rerank(corpus_texts: List[str], collection_name: str, query: str, top_k: int = 6):\n",
    "    # 1) BM25 top ids (in-memory)\n",
    "    bm25_ids = bm25_search(corpus_texts, query, top_n=20)\n",
    "\n",
    "    # 2) Dense search via embeddings (OpenAI)\n",
    "    qvec = get_openai_embeddings([query])[0]\n",
    "    dense_ids = dense_search_qdrant(collection_name, qvec, top_k=20)\n",
    "\n",
    "    # 3) Fuse\n",
    "    fused = rrf([ [str(i) for i in dense_ids], [str(i) for i in bm25_ids] ])\n",
    "\n",
    "    # 4) Simple rerank by cosine similarity of embeddings (local) -- requires retrieving vectors from Qdrant payloads or re-embedding texts\n",
    "    # For demo, re-embed the top fused texts and compute similarity\n",
    "    top_texts = [corpus_texts[int(i)] for i in fused[:20]]\n",
    "    embeddings = get_openai_embeddings(top_texts)\n",
    "    qemb = np.array(qvec).reshape(1, -1)\n",
    "    sims = cosine_similarity(qemb, np.array(embeddings))[0]\n",
    "    ranked_indices = np.argsort(sims)[::-1][:top_k]\n",
    "    final = [fused[i] for i in ranked_indices]\n",
    "    return final\n",
    "\n",
    "# NOTE: This pipeline is illustrative. For production: retrieve vector payloads from Qdrant directly to avoid re-embedding, and use an external reranker (Cohere) if available.\n"
   ]
  },
