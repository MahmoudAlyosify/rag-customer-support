    "def generate_answer_with_openai(system_prompt: str, user_question: str, context_chunks: List[Tuple[int, str]]) -> str:\n",
    "    # context_chunks: list of (source_id, text) to include in the prompt with numbered citations\n",
    "    numbered = '\\n'.join([f'[{i+1}] {txt[:800].replace('\n',' ') }' for i,(i,txt) in enumerate(context_chunks)])\n",
    "    prompt = system_prompt.replace('{retrieved_chunks_with_numbered_sources}', numbered)\n",
    "    prompt += f"\n\nCustomer question: {user_question}\n"\n",
    "    resp = openai.ChatCompletion.create(\n",
    "        model='gpt-4o-mini' if 'gpt-4o-mini' in openai.Model.list()['data'] else 'gpt-4o',\n",
    "        messages=[\n",
    "            {'role':'system', 'content': prompt},\n",
    "            {'role':'user', 'content': user_question},\n",
    "        ],\n",
    "        max_tokens=400,\n",
    "    )\n",
    "    return resp['choices'][0]['message']['content']\n",
    "\n",
    "# Example system prompt (from the guide)\n",
    "system_prompt = '''You are a customer support assistant for {company_name}.\n\nRules:\n- Answer ONLY from the context passages provided below.\n- After every factual claim, cite the source number, e.g. [1].\n- If the answer is not in the context, say so explicitly.\n- Reply in the same language the customer used.\n\nContext passages:\n{retrieved_chunks_with_numbered_sources}'''\n",
    "\n",
    "# generate_answer_with_openai(system_prompt, 'How do I return an item?', [(1,'Return policy text...')])  # requires OpenAI key\n"
   ]
